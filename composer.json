{
    "name": "codego/php-ksip-telnet",
    "description": "FreePBX extension manager via SSH",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kenneth G.",
            "email": "kent14328@gmail.com"
        }
